# boon-app — frontend environment variables
#
# Vite exposes only vars prefixed with VITE_ to the bundle. These are baked
# into the static build at `pnpm build`, so changes require a rebuild.
# Copy this file to .env.local for `pnpm dev`. Production hosting injects
# equivalent public build-time values. These are public values, not secrets.

# Boon API base URL. Used by send, claim, board/profile/receipt, private-tip,
# and attestation views. Self-host/local dev can point this at a compatible API.
VITE_BOON_API_URL=https://api.boonprotocol.com

# Legacy Boon v1 deployment address on Base mainnet. Kept only for old
# claim/receipt compatibility. New sends use BoonV3.
VITE_BOON_CONTRACT=0xfb6662AdaF0611a94322634d5B86203Cfb59d5e8

# Current BoonV3 deployment address on Base mainnet. Used for new public tips,
# pending social-handle settlement, agent recipients, private tips, refunds,
# claims, and optional soulbound gratitude attestations.
VITE_ACTIVE_CONTRACT=v3
VITE_BOON_V3_CONTRACT=0x22aC2E603D4B1CaAb3A8433f1691BA6158A896AF
VITE_BOON_ATTESTATION_CONTRACT=0xC53160EEedb119670A7c13CC7C3709CdE6c9b469

# $BOON token address. Required for private-tip and recipient-proof burns.
VITE_BOON_TOKEN_ADDRESS=0x5Bec0bD17D16641660D66d82da4cF78b46B9EBA3

# Optional Base mainnet read RPCs for wagmi/viem contract reads. If blank, the
# app falls back to no-key public endpoints in code. Browser keys are public
# Vite build values, so restrict by domain in the provider dashboard when used.
VITE_BASE_RPC_URL=
VITE_BASE_RPC_FALLBACK_URLS=https://1rpc.io/base,https://base-rpc.publicnode.com

# Optional Reown/WalletConnect Cloud Project ID. Public client metadata, not a
# secret. Create one at https://cloud.reown.com/.
VITE_WC_PROJECT_ID=
